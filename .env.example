# Copia este archivo a ".env" (sin .example) y completa los valores.
# NUNCA subas el .env real a git (ya está ignorado en .gitignore).

# URL del panel EasDashboard.
#   - En local:      http://127.0.0.1:8000
#   - En producción: https://tu-panel.com   (usa HTTPS: el endpoint devuelve el token de MetaApi)
DASHBOARD_URL=http://127.0.0.1:8000

# La MISMA clave que BOT_API_KEY en el .env del panel.
BOT_API_KEY=la-misma-clave-del-panel

# Cada cuántos segundos el worker consulta el panel y gestiona trailing/entradas.
POLL_SECONDS=30
